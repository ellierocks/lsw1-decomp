#!/usr/bin/env python3
"""
Extract strings from Mac Mach-O __cstring, scan __text for PPC
lis+addi/ori/lwz references, and cross-reference with GC strings by content.

Usage:
  python3 tools/mac_string_xref_scanner.py

Produces:
  docs/symbol_donors/mac_string_xrefs.txt
  docs/symbol_donors/mac_gc_string_match_report.md
  docs/symbol_donors/mac_gc_string_match_table.tsv
"""

import re
import struct
import subprocess
import sys
from collections import defaultdict
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
GC_DOL = ROOT / "orig/GL5E4F/sys/main.dol"
GC_SYMBOLS = ROOT / "config/GL5E4F/symbols.txt"
MAC_LSW1 = ROOT / "orig/mac-debug-symbols/LEGO Star Wars Demo"
MAC_LSW2 = ROOT / "orig/mac-debug-symbols/LEGO Star Wars II"
OUT_DIR = ROOT / "docs/symbol_donors"

SYMBOL_LINE_RE = re.compile(
    r"^(?P<name>\S+)\s+=\s+(?P<section>\.\w+):0x(?P<addr>[0-9A-Fa-f]+);\s+//\s+(?P<meta>.*)$"
)
SIZE_RE = re.compile(r"\bsize:0x([0-9A-Fa-f]+)")

DOL_SECTIONS = [
    (0x000000, 0x80003100, 0x025300, ".init"),
    (0x025300, 0x80258400, 0x15F540, ".text"),
    (0x184840, 0x803B7940, 0x00CC14, ".rodata"),
    (0x191454, 0x803C4560, 0x000114, ".data_ext"),
    (0x191568, 0x803C4680, 0x0084A0, ".data"),
    (0x189B00, 0x8018CB00, 0x023B40, ".data_early"),
]


# PPC reference patterns: lis $rD, hi16 / addi $rA, $rD, lo16
# Also: ori, lwz, lbz, lhz, lfs
def extract_macho_cstring(exe: Path, arch: str = "") -> dict[int, bytes]:
    """Extract __TEXT,__cstring as {address: bytes}."""
    cmd = ["llvm-objdump", "-d", "--section=__TEXT,__cstring", "--no-show-raw-insn", "-macho"]
    if arch:
        cmd.extend(["-arch", arch])
    cmd.append(str(exe))
    res = subprocess.run(cmd, capture_output=True, text=True)
    strings = {}
    current_addr = None
    current_bytes = bytearray()
    for line in res.stdout.splitlines():
        parts = line.split()
        if not parts:
            continue
        if parts[0].endswith(":"):
            try:
                addr = int(parts[0].rstrip(":"), 16)
            except ValueError:
                continue
            if current_addr is not None and current_bytes:
                strings[current_addr] = bytes(current_bytes)
            current_addr = addr
            current_bytes = bytearray()
        elif parts[0] == ".byte" or parts[0].startswith("0x"):
            for p in parts:
                if p.startswith("0x"):
                    try:
                        current_bytes.append(int(p, 16))
                    except ValueError:
                        pass
        else:
            # Assume ascii representation
            for p in parts:
                if len(p) == 1 and 32 <= ord(p) < 127:
                    current_bytes.append(ord(p))
    
    if current_addr is not None and current_bytes:
        strings[current_addr] = bytes(current_bytes)
    return strings


def extract_macho_cstring_hex(exe: Path, arch: str = "") -> dict[int, bytes]:
    """Extract __cstring via -full-contents for reliable hex."""
    cmd = ["llvm-objdump", "--full-contents", "--section=__TEXT,__cstring", "-macho"]
    if arch:
        cmd.extend(["-arch", arch])
    cmd.append(str(exe))
    res = subprocess.run(cmd, capture_output=True, text=True)
    strings = {}
    current_addr = None
    hex_bytes = bytearray()
    
    for line in res.stdout.splitlines():
        parts = line.split()
        if not parts:
            continue
        # Expected: <addr> <hex> <hex> <hex> <hex>  <ascii>
        try:
            addr = int(parts[0].rstrip(":"), 16)
        except ValueError:
            continue
        
        # Collect hex bytes
        data = bytearray()
        for p in parts[1:]:
            if len(p) == 2 and all(c in "0123456789abcdefABCDEF" for c in p):
                data.append(int(p, 16))
            elif len(p) == 4 and all(c in "0123456789abcdefABCDEF" for c in p):
                data.append(int(p[:2], 16))
                data.append(int(p[2:], 16))
            elif len(p) > 4:
                break
        
        if data:
            strings[addr] = bytes(data)
    
    return strings


def extract_text_hex(exe: Path, arch: str = "") -> tuple[bytes, int]:
    """Extract __TEXT,__text as raw bytes + base address."""
    cmd = ["llvm-objdump", "--full-contents", "--section=__TEXT,__text", "-macho"]
    if arch:
        cmd.extend(["-arch", arch])
    cmd.append(str(exe))
    res = subprocess.run(cmd, capture_output=True, text=True)
    
    chunks = []  # (addr, bytes)
    for line in res.stdout.splitlines():
        parts = line.split()
        if not parts:
            continue
        try:
            addr = int(parts[0].rstrip(":"), 16)
        except ValueError:
            continue
        data = bytearray()
        for p in parts[1:]:
            if len(p) == 2 and all(c in "0123456789abcdefABCDEF" for c in p):
                data.append(int(p, 16))
            else:
                break
        if data:
            chunks.append((addr, bytes(data)))
    
    if not chunks:
        return b"", 0
    
    base = chunks[0][0]
    # Fill gaps with zeros
    result = bytearray()
    prev_end = base
    for addr, data in chunks:
        if addr > prev_end:
            result.extend(b'\x00' * (addr - prev_end))
        result.extend(data)
        prev_end = addr + len(data)
    return bytes(result), base


def scan_text_for_string_refs(code: bytes, base_addr: int, strings: dict[int, bytes],
                               func_map: dict[int, str], binary_name: str) -> list[dict]:
    """Scan PPC code for lis+addi/ori/load patterns referencing strings."""
    # Build string set for lookup
    str_addrs = set(strings.keys())
    
    refs = []
    code_len = len(code)
    
    for offset in range(0, code_len - 4, 4):
        inst = struct.unpack(">I", code[offset:offset+4])[0]
        opcode = inst >> 26
        if opcode != 15:  # not addis/lis
            continue
        rd = (inst >> 21) & 0x1F
        ra = (inst >> 16) & 0x1F
        if ra != 0:
            continue
        imm = inst & 0xFFFF
        # lis sets high 16 bits
        hi = imm << 16
        
        addr = base_addr + offset
        
        # Search forward for a use of rd
        for lookahead in range(4, min(256, code_len - offset - 4), 4):
            inst2 = struct.unpack(">I", code[offset+lookahead:offset+lookahead+4])[0]
            op2 = inst2 >> 26
            use_rd = (inst2 >> 21) & 0x1F
            use_ra = (inst2 >> 16) & 0x1F
            lo = inst2 & 0xFFFF
            if use_ra != rd:
                continue
            
            target = None
            if op2 == 14:   # addi
                target = (hi + lo) & 0xFFFFFFFF
            elif op2 == 24:  # ori
                target = (hi | lo) & 0xFFFFFFFF
            elif op2 in (32, 34, 35, 40):  # lwz, lbz, lhz, lfs
                target = (hi + lo) & 0xFFFFFFFF
            
            if target and target in str_addrs:
                # Find containing function
                func_name = "<unknown>"
                func_start = 0
                for f_addr in sorted(func_map.keys(), reverse=True):
                    if addr >= f_addr:
                        func_name = func_map[f_addr]
                        func_start = f_addr
                        break
                
                text = strings[target]
                try:
                    str_content = text.split(b'\x00')[0].decode('latin-1', errors='replace')
                except:
                    str_content = repr(text)
                
                refs.append({
                    'addr': addr,
                    'func_name': func_name,
                    'func_start': func_start,
                    'str_addr': target,
                    'content': str_content,
                    'binary': binary_name,
                    'pattern': f'lis op{op2}',
                })
                break  # only first ref per lis
    
    return refs


def parse_gc_strings_and_xrefs() -> tuple[dict, dict, dict]:
    """Parse GC symbols.txt for str_* entries + build/xrefs/string_xrefs.txt."""
    # Read string_xrefs.txt: str_name str_addr func_name func_addr ref_addr pattern
    xref_path = ROOT / "build/xrefs/string_xrefs.txt"
    str_to_func = defaultdict(set)
    func_to_strs = defaultdict(set)
    str_addr_to_name = {}
    
    if xref_path.exists():
        for line in xref_path.read_text().splitlines():
            parts = line.split()
            if len(parts) >= 4 and parts[0].startswith("str_"):
                str_name = parts[0]
                try:
                    str_addr = int(parts[1], 16)
                except ValueError:
                    continue
                func_name = parts[2]
                str_addr_to_name[str_addr] = str_name
                str_to_func[str_name].add(func_name)
                func_to_strs[func_name].add(str_name)
    
    # Read actual string content from DOL
    dol_data = GC_DOL.read_bytes()
    
    # DOL sections for string reading
    dol_secs = [
        (0x189B00, 0x8018CB00, 0x023B40),  # .data_early (has strings)
        (0x184840, 0x803B7940, 0x00CC14),  # .rodata
        (0x191568, 0x803C4680, 0x0084A0),  # .data
    ]
    
    str_name_to_content = {}
    for line in GC_SYMBOLS.read_text().splitlines():
        m = SYMBOL_LINE_RE.match(line)
        if not m:
            continue
        name = m.group("name")
        if not name.startswith("str_"):
            continue
        sec_name = m.group("section")
        addr = int(m.group("addr"), 16)
        meta = m.group("meta")
        size_m = SIZE_RE.search(meta)
        size = int(size_m.group(1), 16) if size_m else 0
        
        for file_off, base_addr, sec_size in dol_secs:
            if base_addr <= addr < base_addr + sec_size:
                offset = file_off + (addr - base_addr)
                raw = dol_data[offset:offset + size] if size else dol_data[offset:offset+512]
                content = raw.split(b'\x00')[0].decode('latin-1', errors='replace')
                str_name_to_content[name] = content
                break
    
    return str_to_func, func_to_strs, str_name_to_content


def main():
    print("=" * 60)
    print("Mac String Xref Scanner & GC Cross-Reference")
    print("=" * 60)
    OUT_DIR.mkdir(parents=True, exist_ok=True)
    
    # 1. Load GC string info
    print("\n[1] Loading GC string xrefs and content...")
    gc_str_to_func, gc_func_to_strs, gc_str_content = parse_gc_strings_and_xrefs()
    print(f"  {len(gc_str_to_func)} GC str_* symbols with func xrefs")
    print(f"  {len(gc_str_content)} with content extracted")
    
    # Build content->GC string name lookup
    content_to_gc = {}
    for name, content in gc_str_content.items():
        key = content.rstrip('\x00').strip()
        if key:
            content_to_gc[key] = name
    
    # Also build partial matches for shorter strings
    # GC strings sometimes end earlier than Mac strings
    for name, content in gc_str_content.items():
        key = content.rstrip('\x00').strip()
        for i in range(4, min(20, len(key))):
            subkey = key[:i]
            if subkey not in content_to_gc:
                content_to_gc[subkey] = name
    
    print(f"  {len(content_to_gc)} unique string keys for matching")
    
    # 2. Process each Mac binary
    print("\n[2] Extracting Mac strings and code...")
    
    all_refs = []
    mac_strings_all = {}
    
    for label, exe, arch in [
        ("LSW1 Demo", MAC_LSW1, ""),
        ("LSW2 PPC", MAC_LSW2, "ppc"),
    ]:
        print(f"\n  --- {label} ---")
        
        # Extract strings
        mac_strings = extract_macho_cstring_hex(exe, arch)
        print(f"  String regions: {len(mac_strings)}")
        
        # Extract code
        code, base = extract_text_hex(exe, arch)
        print(f"  Code bytes: {len(code):,} at 0x{base:x}")
        
        # Get function symbols
        cmd = ["llvm-nm", "-a"]
        if arch:
            cmd.extend(["-arch", arch])
        cmd.append(str(exe))
        res = subprocess.run(cmd, capture_output=True, text=True)
        func_map = {}
        for line in res.stdout.splitlines():
            parts = line.split()
            if len(parts) >= 3 and parts[1] in ('T', 't'):
                try:
                    func_map[int(parts[0], 16)] = parts[2]
                except ValueError:
                    pass
        print(f"  Text symbols: {len(func_map)}")
        
        # Scan for string refs
        refs = scan_text_for_string_refs(code, base, mac_strings, func_map, label)
        print(f"  String refs found: {len(refs)}")
        
        all_refs.extend(refs)
        mac_strings_all[label] = mac_strings
    
    # 3. Cross-reference by content
    print("\n[3] Cross-referencing Mac string refs with GC strings...")
    
    mac_func_to_gc = defaultdict(set)  # mac_func -> set of [(gc_str_name, gc_func)]
    matched_refs = []
    
    for ref in all_refs:
        content = ref['content'].strip()
        if not content or len(content) < 3:
            continue
        
        matched = False
        # Check for exact content match
        if content in content_to_gc:
            gc_name = content_to_gc[content]
            gc_funcs = gc_str_to_func.get(gc_name, set())
            matched_refs.append((ref, gc_name, gc_funcs))
            mac_func_to_gc[ref['func_name']].add((gc_name, tuple(gc_funcs)))
            matched = True
        else:
            # Try partial match: Mac string might be longer
            for gc_key, gc_name in content_to_gc.items():
                if content.startswith(gc_key) or content == gc_key:
                    gc_funcs = gc_str_to_func.get(gc_name, set())
                    matched_refs.append((ref, gc_name, gc_funcs))
                    mac_func_to_gc[ref['func_name']].add((gc_name, tuple(gc_funcs)))
                    matched = True
                    break
        
        if not matched:
            # Try: Mac string might be truncated
            for gc_key, gc_name in content_to_gc.items():
                if gc_key.startswith(content):
                    gc_funcs = gc_str_to_func.get(gc_name, set())
                    matched_refs.append((ref, gc_name, gc_funcs))
                    mac_func_to_gc[ref['func_name']].add((gc_name, tuple(gc_funcs)))
                    matched = True
                    break
    
    print(f"  Content-matched refs: {len(matched_refs)}")
    print(f"  Unique Mac functions with string evidence: {len(mac_func_to_gc)}")
    
    # 4. Write outputs
    print("\n[4] Writing output files...")
    
    # 4a. All Mac string xrefs
    xref_lines = [
        "# Mac String Xrefs",
        f"# Total: {len(all_refs)}",
        "# Columns: ref_addr | binary | str_addr | pattern | func_name | string_content",
        ""
    ]
    for ref in sorted(all_refs, key=lambda r: (r['binary'], r['addr'])):
        xref_lines.append(
            f"0x{ref['addr']:08x} | {ref['binary']:12s} | 0x{ref['str_addr']:08x} | "
            f"{ref['pattern']:10s} | {ref['func_name']:40s} | \"{ref['content'][:100]}\""
        )
    (OUT_DIR / "mac_string_xrefs.txt").write_text("\n".join(xref_lines) + "\n")
    print(f"  Wrote {OUT_DIR}/mac_string_xrefs.txt ({len(all_refs)} refs)")
    
    # 4b. Match report
    md_lines = [
        "# Mac-GC String Cross-Reference Report",
        "",
        f"- Mac string refs found: {len(all_refs)}",
        f"- Content-matched to GC strings: {len(matched_refs)}",
        f"- Unique Mac functions linked to GC via shared strings: {len(mac_func_to_gc)}",
        "",
        "Each entry shows a Mac function referencing a string also referenced by a GC function.",
        "This provides strong evidence they are the same function.",
        "",
        "## Matched References",
        "",
        "| # | Mac Function | Binary | String Content | GC String | GC Functions Referencing It |",
        "|---|-------------|--------|---------------|-----------|----------------------------|",
    ]
    
    # Sort: mac_funcs that map to named (non-fn_) GC funcs first
    def sort_key(item):
        mac_func, gc_matches = item
        best = 0
        for gc_name, gc_funcs in gc_matches:
            for gf in gc_funcs:
                if not gf.startswith("fn_"):
                    best = max(best, 3)
                else:
                    best = max(best, 1)
        return -best
    
    count = 0
    for mac_func, gc_matches in sorted(mac_func_to_gc.items(), key=sort_key):
        for gc_name, gc_funcs in gc_matches:
            gc_funcs_str = ", ".join(sorted(gc_funcs)[:5]) if gc_funcs else "(orphan)"
            count += 1
            if count > 300:
                break
            
            # Find a sample string content for this match
            sample_content = ""
            for ref in all_refs:
                if ref['func_name'] == mac_func:
                    for gcn, gcf in mac_func_to_gc[mac_func]:
                        if gcn == gc_name:
                            sample_content = ref['content']
                            break
                    if sample_content:
                        break
            
            md_lines.append(
                f"| {count} | `{mac_func[:50]}` | {gc_matches.copy().pop()[0].split('_')[0] if gc_matches else '?'} "
                f"| `{sample_content[:70]}` | {gc_name} | `{gc_funcs_str}` |"
            )
        if count > 300:
            md_lines.append("| ... | (truncated) | | | |")
            break
    
    # Add stats for matched references
    md_lines.extend([
        "",
        "---",
        "",
        "## Summary Statistics",
        "",
        f"| Metric | Count |",
        "|--------|-------|",
        f"| Mac string references found | {len(all_refs)} |",
        f"| Content-matched to GC strings | {len(matched_refs)} |",
        f"| Unique Mac functions with string evidence | {len(mac_func_to_gc)} |",
    ])
    
    # Count how many mac functions map to named vs unnamed GC funcs
    named_matches = 0
    inamed_matches = 0
    for mac_func, gc_matches in mac_func_to_gc.items():
        for gc_name, gc_funcs in gc_matches:
            for gf in gc_funcs:
                if gf.startswith("fn_"):
                    inamed_matches += 1
                else:
                    named_matches += 1
    
    md_lines.extend([
        f"| Mac func -> existing GC named func | {named_matches} |",
        f"| Mac func -> GC unnamed (fn_*) func | {inamed_matches} |",
    ])
    
    (OUT_DIR / "mac_gc_string_match_report.md").write_text("\n".join(md_lines) + "\n")
    print(f"  Wrote {OUT_DIR}/mac_gc_string_match_report.md")
    
    # 4c. TSV of matched refs
    tsv_lines = [
        "# mac_func\tbinary\tstring_content\tgc_string\tgc_function\tref_addr"
    ]
    for ref, gc_name, gc_funcs in matched_refs:
        for gf in sorted(gc_funcs)[:3]:
            tsv_lines.append(
                f"{ref['func_name']}\t{ref['binary']}\t{ref['content'][:120]}\t"
                f"{gc_name}\t{gf}\t0x{ref['addr']:08x}"
            )
    (OUT_DIR / "mac_gc_string_match_table.tsv").write_text("\n".join(tsv_lines) + "\n")
    print(f"  Wrote {OUT_DIR}/mac_gc_string_match_table.tsv ({len(matched_refs)} rows)")
    
    # 4d. Proposed renames for unnamed GC functions
    rename_lines = [
        "# Proposed GC Function Renames (from Mac string evidence)",
        "# confidence | mac_name -> gc_fn_name | evidence_string",
        ""
    ]
    seen = set()
    for mac_func, gc_matches in sorted(mac_func_to_gc.items(), key=sort_key):
        for gc_name, gc_funcs in gc_matches:
            for gf in gc_funcs:
                if gf.startswith("fn_") and mac_func not in seen:
                    clean = mac_func.lstrip("_")
                    rename_lines.append(
                        f"MEDIUM | {clean} -> {gf} | shared string {gc_name}"
                    )
                    seen.add(mac_func)
    
    (OUT_DIR / "proposed_gc_renames_v2.txt").write_text("\n".join(rename_lines) + "\n")
    print(f"  Wrote {OUT_DIR}/proposed_gc_renames_v2.txt ({len(rename_lines)-2} proposals)")
    
    print("\n" + "=" * 60)
    print("DONE")
    sys.exit(0)


if __name__ == "__main__":
    main()
