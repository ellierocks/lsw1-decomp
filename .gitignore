# IDE folders
.idea/
.vs/
*.swp
*.swo
*~

# Caches
__pycache__
.mypy_cache
.cache/

# Original files
orig/*/*
!orig/*/.gitkeep
# Encrypted original DOL for CI (ciphertext only; decrypted via the ORIG_KEY secret)
!orig/GL5E4F/sys/
!orig/GL5E4F/sys/main.dol.enc
*.dol
*.rel
*.elf
*.o
*.map
*.MAP
*.iso

# Build files
build/
.ninja_*
build.ninja

# decompctx output
ctx.*
*.ctx

# Generated configs
objdiff.json
compile_commands.json

# Logs and temporary files
*.log
dtk-split.log

# RAM dumps (24 MiB MEM1 images) — keep snapshots local, see docs/ramdump_workflow.md
/dumps/*.raw
/dumps/*.bin

# Miscellaneous
/*.txt
*.exe
